datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Alert {
  id        String   @id @default(uuid())
  type      String   
  message   String
  status    String   @default("ACTIVE") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt]) 
}